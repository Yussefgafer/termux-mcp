#!/data/data/com.termux/files/usr/bin/sh

set -eu

BASE_DIR="${TERMUX_MCP_HOME:-$HOME/termux-mcp}"
RUNTIME_DIR="${TERMUX_MCP_RUNTIME_DIR:-$HOME/.termux-mcp}"
PID_FILE="$RUNTIME_DIR/termux-mcp.pid"
LOG_FILE="$RUNTIME_DIR/termux-mcp.log"
HOST="${TERMUX_MCP_HOST:-0.0.0.0}"
PORT="${TERMUX_MCP_PORT:-8765}"

mkdir -p "$RUNTIME_DIR"

if [ -f "$PID_FILE" ]; then
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
    echo "termux-mcp is already running with pid $PID"
    exit 0
  fi
  rm -f "$PID_FILE"
fi

cd "$BASE_DIR"
rm -f "$PID_FILE"
setsid sh -c 'exec node ./src/server.js >>"$1" 2>&1 </dev/null' sh "$LOG_FILE" &
PID=$!
echo "$PID" >"$PID_FILE"
sleep 1

if [ -f "$PID_FILE" ]; then
  PID="$(cat "$PID_FILE" 2>/dev/null || true)"
fi

if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
  echo "termux-mcp started"
  echo "pid: $PID"
  echo "url: http://$HOST:$PORT/mcp"
  echo "log: $LOG_FILE"
else
  echo "termux-mcp failed to start; see $LOG_FILE"
  rm -f "$PID_FILE"
  exit 1
fi
