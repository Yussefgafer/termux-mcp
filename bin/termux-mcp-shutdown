#!/data/data/com.termux/files/usr/bin/sh

set -eu

RUNTIME_DIR="${TERMUX_MCP_RUNTIME_DIR:-$HOME/.termux-mcp}"
PID_FILE="$RUNTIME_DIR/termux-mcp.pid"

if [ ! -f "$PID_FILE" ]; then
  echo "termux-mcp is not running"
  exit 0
fi

PID="$(cat "$PID_FILE" 2>/dev/null || true)"
if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
  kill "$PID"
  rm -f "$PID_FILE"
  echo "termux-mcp stopped"
else
  rm -f "$PID_FILE"
  echo "termux-mcp is not running"
fi
